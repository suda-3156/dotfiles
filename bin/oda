#!/usr/bin/env python3
"""Open Obsidian daily note.

Usage: oda [--print-path] [YYYY-MM-DD]

Set vault path to OBSIDIAN_DAILY_VAULT_PATH
"""

from __future__ import annotations

import argparse
import datetime as dt
import json
import os
import re
import subprocess
import sys
import time
import urllib.parse
from dataclasses import dataclass
from pathlib import Path
from typing import NoReturn

SCRIPT_NAME = "oda"
HIDE_APP_DELAY = 0.5

APPLESCRIPT_HIDE_APP = 'tell application "System Events" to set visible of application process "{app}" to false'


# This script should not generate __pycache__ dir
sys.dont_write_bytecode = True


def fail(message: str, code: int = 1) -> NoReturn:
    print(message, file=sys.stderr)
    raise SystemExit(code)


@dataclass
class Args:
    print_path_only: bool
    target_date: str


def parse_args() -> type[Args]:
    parser = argparse.ArgumentParser(
        prog=SCRIPT_NAME,
        usage=f"{SCRIPT_NAME} [--print-path] [YYYY-MM-DD]",
        add_help=True,
    )
    parser.add_argument("--print-path", action="store_true", dest="print_path_only")
    parser.add_argument("target_date", nargs="?")
    args = parser.parse_args(namespace=Args)

    date_str = args.target_date or dt.date.today().isoformat()
    if not re.fullmatch(r"\d{4}-\d{2}-\d{2}", date_str):
        fail("Usage: odaily [--print-path] [YYYY-MM-DD]")
    args.target_date = date_str
    return args


def resolve_vault_path() -> Path | None:
    env_vault_path = os.environ.get("OBSIDIAN_DAILY_VAULT_PATH")
    if env_vault_path:
        return Path(env_vault_path).expanduser()

    # Although we can get list of vault paths from ~/Library/Application Support/obsidian/obsidian.json
    # we don't implement fallback for simplicity

    return None


def daily_folder_from_config(vault_path: Path) -> str | None:
    config_path = vault_path / ".obsidian" / "daily-notes.json"
    if not config_path.is_file():
        return None

    try:
        with config_path.open("r", encoding="utf-8") as file:
            config = json.load(file)
    except (OSError, json.JSONDecodeError):
        return None

    folder = str(config.get("folder", "")).strip()
    return folder or None


def find_note(vault_path: Path, date_str: str) -> Path | None:
    folder = daily_folder_from_config(vault_path)
    if folder:
        candidate = vault_path / folder / f"{date_str}.md"
        if candidate.is_file():
            return candidate

    candidate = vault_path / f"{date_str}.md"
    if candidate.is_file():
        return candidate

    target_name = f"{date_str}.md"
    for root, dirs, files in os.walk(vault_path):
        dirs[:] = [name for name in dirs if name != ".obsidian"]
        if target_name in files:
            return Path(root) / target_name

    return None


def hide_obsidian() -> None:
    try:
        subprocess.run(
            ["osascript", "-e", APPLESCRIPT_HIDE_APP.format(app="Obsidian")],
            text=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )
    except OSError:
        pass


def exec_nvim(note_path: Path) -> None:
    os.execvp("nvim", ["nvim", str(note_path)])


def main() -> None:
    args = parse_args()
    target_date = args.target_date

    vault_path = resolve_vault_path()
    if vault_path is None:
        fail("Could not resolve Obsidian vault path.")
    if not vault_path.exists():
        fail(f"Vault path does not exist: {vault_path}")

    note_path = find_note(vault_path, target_date)
    if note_path:
        if args.print_path_only:
            print(note_path)
            return
        exec_nvim(note_path)

    today = dt.date.today().isoformat()
    if target_date != today:
        fail(f"Daily note '{target_date}' does not exist.")

    vault_query = urllib.parse.quote(vault_path.name, safe="")
    subprocess.run(["open", f"obsidian://daily?vault={vault_query}"], check=True)

    for _ in range(20):
        time.sleep(0.25)
        note_path = find_note(vault_path, target_date)
        if note_path:
            break

    if note_path is None:
        fail(f"Daily note '{target_date}' was not found after generation.")
    final_note_path = note_path

    if args.print_path_only:
        print(final_note_path)

    time.sleep(HIDE_APP_DELAY)
    hide_obsidian()

    if not args.print_path_only:
        exec_nvim(final_note_path)


if __name__ == "__main__":
    main()
