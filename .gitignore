# White list
*
!*/

!.gitignore
!.gitallowed
!README.md
!TODO.md

!*.sh
!*.symlink
!*.example
!Brewfile
!install*

# tmux
!.config/tmux/tmux-statusline-left

# nvim
!.config/nvim.symlink/**/*lua
!.config/nvim.symlink/.stylua.toml
!.config/svim.symlink/**/*lua
!.config/svim.symlink/.stylua.toml

# zsh
!.config/zsh/*.zsh
!*zshrc*

# scripts
!/scripts/*

# bin
!/bin/*

# karabiner
!/extras/karabiner/complex_modifications/*.json

# vscode
!/extras/vscode/extensions
!/extras/vscode/extensions.old
!/extras/vscode/keybindings.json5
!/extras/vscode/settings.json5
